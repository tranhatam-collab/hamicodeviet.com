---
import AppLayout from '../../layouts/AppLayout.astro';

export function getStaticPaths() {
  return [{ params: { slug: '_' } }];
}
---

<AppLayout title="Khóa học — HaMi Code Việt">
  <div id="course-detail-root">
    <div class="auth-container"><div class="auth-card"><h1 class="auth-title">Đang tải...</h1></div></div>
  </div>

  <script type="module">
    import { getCurrentUser, apiCall, clearToken } from '../../lib/api';

    const root = document.getElementById('course-detail-root')!;
    const slug = window.location.pathname.split('/').pop();

    async function renderCourse() {
      const user = await getCurrentUser();
      if (!user) { window.location.href = '/login'; return; }

      const res = await fetch(`https://api.hamicodeviet.com/courses/${slug}`);
      const { course, lessons, progress } = await res.json();
      if (!course) { root.innerHTML = '<p>Khóa học không tìm thấy.</p>'; return; }

      const progressMap = new Map((progress || []).map((p: any) => [p.lesson_id, p.status]));
      const completedCount = lessons.filter((l: any) => progressMap.get(l.id) === 'completed').length;
      const percent = lessons.length > 0 ? Math.round((completedCount / lessons.length) * 100) : 0;

      root.innerHTML = `
        <div class="dashboard">
          <aside class="sidebar">
            <div class="sidebar-logo">HaMi <span class="code">&lt;CODE&gt;</span> Việt</div>
            <nav><ul class="sidebar-nav">
              <li><a href="/dashboard">📊 Dashboard</a></li>
              <li><a href="/courses" class="active">📚 Khóa học</a></li>
              <li><a href="/billing">💳 Gói đăng ký</a></li>
              <li><a href="/settings">⚙️ Cài đặt</a></li>
              <li><a href="#" id="logout-btn">🚪 Đăng xuất</a></li>
            </ul></nav>
          </aside>
          <main class="dashboard-main">
            <a href="/courses" style="color:var(--color-primary);margin-bottom:16px;display:inline-block">← Quay lại khóa học</a>
            <div class="dashboard-header">
              <h1 class="dashboard-title">${course.title_vi}</h1>
            </div>
            <p style="color:var(--color-text-muted);margin-bottom:24px">${course.description_vi}</p>

            <div class="course-info-bar">
              <span>⏱ ${course.duration_hours} giờ</span>
              <span>📊 ${course.level}</span>
              <span>📚 ${lessons.length} bài học</span>
              <span>${course.price_cents === 0 ? 'Miễn phí' : (course.price_cents / 1000).toLocaleString() + 'K VND'}</span>
            </div>

            ${percent > 0 ? `
              <div class="progress-bar-container" style="margin:24px 0">
                <div class="progress-bar-info">
                  <span>Tiến độ: ${completedCount}/${lessons.length} bài</span>
                  <span>${percent}%</span>
                </div>
                <div class="progress-bar"><div class="progress-fill" style="width:${percent}%"></div></div>
              </div>
            ` : ''}

            <div class="lesson-list">
              ${lessons.map((l: any) => {
                const status = progressMap.get(l.id);
                const icon = status === 'completed' ? '✅' : status === 'in_progress' ? '▶️' : '⭕';
                return `
                  <a href="/lesson/${l.id}" class="lesson-item">
                    <span class="lesson-icon">${icon}</span>
                    <div class="lesson-info">
                      <span class="lesson-number">Bài ${l.lesson_number}</span>
                      <span class="lesson-title">${l.title_vi}</span>
                      <span class="lesson-meta">${l.duration_min} phút · ${l.level}</span>
                    </div>
                    ${l.is_free ? '<span class="badge-free">Free</span>' : ''}
                  </a>
                `;
              }).join('')}
            </div>

            ${course.price_cents === 0 ? `
              <button id="enroll-btn" class="btn btn-primary" style="margin-top:24px">Đăng ký khóa học (miễn phí)</button>
            ` : percent === 0 ? `
              <button id="enroll-btn" class="btn btn-primary" style="margin-top:24px">Đăng ký khóa học</button>
            ` : ''}
          </main>
        </div>
      `;

      document.getElementById('enroll-btn')?.addEventListener('click', async () => {
        const r = await apiCall(`/courses/${slug}/enroll`, 'POST');
        const d = await r.json();
        if (d.requiresPayment) {
          window.location.href = '/billing';
        } else if (d.enrolled) {
          window.location.reload();
        }
      });

      document.getElementById('logout-btn')?.addEventListener('click', (e) => {
        e.preventDefault(); clearToken(); window.location.href = '/login';
      });
    }

    renderCourse();
  </script>
</AppLayout>
