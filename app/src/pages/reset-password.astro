---
import AppLayout from '../layouts/AppLayout.astro';
---

<AppLayout title="Đặt lại mật khẩu — HaMi Code Việt">
  <div class="auth-container">
    <div class="auth-card">
      <div class="auth-logo">
        <a href="/">HaMi <span class="code">&lt;CODE&gt;</span> Việt</a>
      </div>
      <div id="content">
        <h1 class="auth-title">Đặt lại mật khẩu</h1>
        <p class="auth-subtitle">Nhập mật khẩu mới</p>

        <div id="alert" class="alert alert--info" style="display:none;"></div>

        <form id="reset-form">
          <div class="form-group">
            <label class="form-label" for="password">Mật khẩu mới</label>
            <input class="form-input" type="password" id="password" name="password" required minlength="8" placeholder="Tối thiểu 8 ký tự" />
          </div>
          <div class="form-group">
            <label class="form-label" for="confirmPassword">Xác nhận mật khẩu</label>
            <input class="form-input" type="password" id="confirmPassword" name="confirmPassword" required placeholder="Nhập lại mật khẩu" />
          </div>
          <button type="submit" class="btn btn--primary btn--block btn--lg">Đặt lại mật khẩu</button>
        </form>
      </div>
    </div>
  </div>

  <script type="module">
    import { apiFetch } from '../lib/api';

    const form = document.getElementById('reset-form') as HTMLFormElement;
    const alert = document.getElementById('alert') as HTMLDivElement;
    const params = new URLSearchParams(window.location.search);
    const token = params.get('token');

    if (!token) {
      const _e = document.getElementById('content'); if (_e) _e.innerHTML = `
        <h1 class="auth-title">Liên kết không hợp lệ</h1>
        <p class="auth-subtitle">Thiếu token đặt lại mật khẩu.</p>
        <a href="/forgot-password" class="btn btn--primary btn--block">Yêu cầu lại</a>
      `;
    }

    function showAlert(msg: string, type: string = 'error') {
      alert.textContent = msg;
      alert.className = `alert alert--${type}`;
      alert.style.display = 'block';
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const password = formData.get('password') as string;
      const confirmPassword = formData.get('confirmPassword') as string;

      if (password !== confirmPassword) {
        showAlert('Mật khẩu không khớp.');
        return;
      }
      if (password.length < 8) {
        showAlert('Mật khẩu phải có ít nhất 8 ký tự.');
        return;
      }

      try {
        await apiFetch('/auth/reset-password', {
          method: 'POST',
          body: JSON.stringify({ token, password }),
        });
        const _e = document.getElementById('content'); if (_e) _e.innerHTML = `
          <h1 class="auth-title">Mật khẩu đã đặt lại!</h1>
          <p class="auth-subtitle">Bạn có thể đăng nhập với mật khẩu mới.</p>
          <a href="/login" class="btn btn--primary btn--block btn--lg">Đăng nhập</a>
        `;
      } catch {
        showAlert('Liên kết đã hết hạn hoặc không hợp lệ.');
      }
    });
  </script>
</AppLayout>
