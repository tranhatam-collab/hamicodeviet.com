---
import AppLayout from '../layouts/AppLayout.astro';
---

<AppLayout title="Quên mật khẩu — HaMi Code Việt">
  <div class="auth-container">
    <div class="auth-card">
      <div class="auth-logo">
        <a href="/">HaMi <span class="code">&lt;CODE&gt;</span> Việt</a>
      </div>
      <h1 class="auth-title">Quên mật khẩu</h1>
      <p class="auth-subtitle">Nhập email để nhận link đặt lại mật khẩu</p>

      <div id="alert" class="alert alert--info" style="display:none;"></div>

      <form id="forgot-form">
        <div class="form-group">
          <label class="form-label" for="email">Email</label>
          <input class="form-input" type="email" id="email" name="email" required placeholder="ban@email.com" />
        </div>
        <button type="submit" class="btn btn--primary btn--block btn--lg">Gửi link đặt lại</button>
      </form>

      <p class="auth-footer">
        <a href="/login">Quay lại đăng nhập</a>
      </p>
    </div>
  </div>

  <script type="module">
    import { apiFetch } from '../lib/api';

    const form = document.getElementById('forgot-form') as HTMLFormElement;
    const alert = document.getElementById('alert') as HTMLDivElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const email = formData.get('email') as string;
      try {
        await apiFetch('/auth/forgot-password', {
          method: 'POST',
          body: JSON.stringify({ email }),
        });
        alert.textContent = 'Nếu email tồn tại, link đặt lại mật khẩu đã được gửi.';
        alert.className = 'alert alert--success';
        alert.style.display = 'block';
      } catch {
        alert.textContent = 'Có lỗi xảy ra. Vui lòng thử lại.';
        alert.className = 'alert alert--error';
        alert.style.display = 'block';
      }
    });
  </script>
</AppLayout>
