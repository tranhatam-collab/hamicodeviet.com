---
import AppLayout from '../layouts/AppLayout.astro';
---

<AppLayout title="Đăng nhập — HaMi Code Việt">
  <div class="auth-container">
    <div class="auth-card">
      <div class="auth-logo">
        <a href="/">HaMi <span class="code">&lt;CODE&gt;</span> Việt</a>
      </div>
      <h1 class="auth-title">Đăng nhập</h1>
      <p class="auth-subtitle">Chào mừng bạn quay lại!</p>

      <div id="alert" class="alert alert--info" style="display:none;"></div>

      <form id="login-form">
        <div class="form-group">
          <label class="form-label" for="email">Email</label>
          <input class="form-input" type="email" id="email" name="email" required autocomplete="email" placeholder="ban@email.com" />
        </div>
        <div class="form-group">
          <label class="form-label" for="password">Mật khẩu</label>
          <input class="form-input" type="password" id="password" name="password" required autocomplete="current-password" placeholder="••••••••" />
        </div>
        <button type="submit" class="btn btn--primary btn--block btn--lg">Đăng nhập</button>
      </form>

      <div class="auth-divider">
        <span>hoặc</span>
      </div>

      <a href="https://api.hamicodeviet.com/auth/google" class="btn btn--google btn--block btn--lg">
        <svg width="18" height="18" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg" style="margin-right:8px;vertical-align:middle">
          <path fill="#4285F4" d="M16.51 8.18c0-.57-.05-1.12-.14-1.65H9v3.12h4.21c-.18.97-.74 1.79-1.58 2.34v1.95h2.55c1.49-1.37 2.33-3.4 2.33-5.76z"/>
          <path fill="#34A853" d="M9 17c2.13 0 3.92-.71 5.22-1.92l-2.55-1.95c-.71.48-1.62.76-2.67.76-2.05 0-3.79-1.39-4.41-3.25H1.96v2.02C3.25 15.21 5.97 17 9 17z"/>
          <path fill="#FBBC05" d="M4.59 10.64c-.16-.48-.25-.99-.25-1.52s.09-1.04.25-1.52V5.58H1.96C1.43 6.63 1.13 7.82 1.13 9.12s.3 2.49.83 3.54l2.63-2.02z"/>
          <path fill="#EA4335" d="M9 4.42c1.16 0 2.2.4 3.02 1.18l2.27-2.27C13.92 1.96 12.13 1.13 9 1.13 5.97 1.13 3.25 2.92 1.96 5.58l2.63 2.02C5.21 5.81 6.95 4.42 9 4.42z"/>
        </svg>
        Đăng nhập với Google
      </a>

      <p class="auth-footer">
        Chưa có tài khoản? <a href="/signup">Đăng ký ngay</a><br />
        <a href="/forgot-password">Quên mật khẩu?</a>
      </p>
    </div>
  </div>

  <script type="module">
    import { apiFetch, setToken } from '../lib/api';

    const form = document.getElementById('login-form') as HTMLFormElement;
    const alert = document.getElementById('alert') as HTMLDivElement;

    function showAlert(msg: string, type: string = 'error') {
      alert.textContent = msg;
      alert.className = `alert alert--${type}`;
      alert.style.display = 'block';
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const email = formData.get('email') as string;
      const password = formData.get('password') as string;

      try {
        const data = await apiFetch('/auth/login', {
          method: 'POST',
          body: JSON.stringify({ email, password }),
        });
        setToken(data.token);
        window.location.href = '/dashboard';
      } catch (err: any) {
        const messages: Record<string, string> = {
          invalid_credentials: 'Email hoặc mật khẩu không đúng.',
          account_suspended: 'Tài khoản đã bị tạm ngưng.',
          account_deleted: 'Tài khoản đã bị xóa.',
          missing_credentials: 'Vui lòng nhập email và mật khẩu.',
        };
        showAlert(messages[err.message] || 'Đăng nhập thất bại. Vui lòng thử lại.');
      }
    });
  </script>
</AppLayout>
