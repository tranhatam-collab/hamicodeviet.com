---
import AppLayout from '../../../layouts/AppLayout.astro';
---

<AppLayout title="Đăng ký mentor — HaMi Code Việt">
  <div id="mr-root">
    <div class="auth-container"><div class="auth-card"><h1 class="auth-title">Đang tải...</h1></div></div>
  </div>

  <script type="module">
    import { getCurrentUser, apiFetch } from '../../../lib/api';

    const root = document.getElementById('mr-root')!;

    const DOMAINS = [
      { value: 'agriculture', label: '🌾 Nông nghiệp' },
      { value: 'tourism', label: '🗺 Du lịch' },
      { value: 'technology', label: '💻 Công nghệ' },
      { value: 'education', label: '🎓 Giáo dục' },
      { value: 'media', label: '📺 Truyền thông' },
      { value: 'environment', label: '🌱 Môi trường' },
      { value: 'health', label: '🏥 Sức khỏe' },
      { value: 'culture', label: '🎭 Văn hóa' },
      { value: 'service', label: '🛎 Dịch vụ' },
      { value: 'business', label: '📈 Kinh doanh' },
    ];

    async function init() {
      const user = await getCurrentUser();
      if (!user) { window.location.href = '/login'; return; }
      renderForm();
    }

    function renderForm() {
      const domainCheckboxes = DOMAINS.map(d => `
        <label style="display:flex;align-items:center;gap:0.4rem;font-size:0.85rem;cursor:pointer">
          <input type="checkbox" name="domains" value="${d.value}" /> ${d.label}
        </label>`).join('');

      root.innerHTML = `
        <div class="dashboard">
          <aside class="sidebar">
            <div class="sidebar-logo">HaMi <span class="code">&lt;CODE&gt;</span> Việt</div>
            <nav><ul class="sidebar-nav">
              <li><a href="/dashboard">📊 Dashboard</a></li>
              <li><a href="/projects" class="active">🔧 Xưởng dự án</a></li>
              <li><a href="/portfolio">🏆 Portfolio</a></li>
              <li><a href="/settings">⚙️ Cài đặt</a></li>
              <li><a href="#" id="logout-btn">🚪 Đăng xuất</a></li>
            </ul></nav>
          </aside>
          <main class="dashboard-main">
            <div class="dashboard-header">
              <div>
                <a href="/projects" style="font-size:0.85rem;color:var(--color-text-muted)">← Xưởng dự án</a>
                <h1 class="dashboard-title" style="margin:0.25rem 0">👤 Đăng ký làm mentor</h1>
              </div>
            </div>
            <div class="dashboard-content">
              <div class="card" style="padding:1.5rem;max-width:600px">
                <p style="font-size:0.85rem;color:var(--color-text-muted);margin:0 0 1rem">
                  Mentor hướng dẫn người học qua 10 bước dự án. Bạn sẽ quan sát, giao nhiệm vụ nhỏ,
                  phản hồi và đánh giá. Không làm hộ — mà giúp người học tự làm.
                </p>
                <form id="mentor-form" style="display:flex;flex-direction:column;gap:1rem">
                  <div>
                    <label style="font-size:0.8rem;display:block;margin-bottom:0.25rem">Tên hiển thị *</label>
                    <input type="text" id="m-name" required style="width:100%;padding:0.5rem;border:1px solid var(--color-border);border-radius:6px" />
                  </div>
                  <div>
                    <label style="font-size:0.8rem;display:block;margin-bottom:0.25rem">Giới thiệu (Việt)</label>
                    <textarea id="m-bio" rows="3" placeholder="Kinh nghiệm, chuyên môn, cách bạn hướng dẫn" style="width:100%;padding:0.5rem;border:1px solid var(--color-border);border-radius:6px"></textarea>
                  </div>
                  <div>
                    <label style="font-size:0.8rem;display:block;margin-bottom:0.25rem">Bio (English)</label>
                    <textarea id="m-bio-en" rows="2" style="width:100%;padding:0.5rem;border:1px solid var(--color-border);border-radius:6px"></textarea>
                  </div>
                  <div>
                    <label style="font-size:0.8rem;display:block;margin-bottom:0.25rem">Chuyên môn * (ngăn cách bởi dấu phẩy)</label>
                    <input type="text" id="m-expertise" required placeholder="vd: Python, UX, Marketing, Nông nghiệp" style="width:100%;padding:0.5rem;border:1px solid var(--color-border);border-radius:6px" />
                  </div>
                  <div>
                    <label style="font-size:0.8rem;display:block;margin-bottom:0.5rem">Lĩnh vực hướng dẫn</label>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem">${domainCheckboxes}</div>
                  </div>
                  <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:0.75rem">
                    <div>
                      <label style="font-size:0.8rem;display:block;margin-bottom:0.25rem">Số năm KN</label>
                      <input type="number" id="m-years" min="0" value="0" style="width:100%;padding:0.5rem;border:1px solid var(--color-border);border-radius:6px" />
                    </div>
                    <div>
                      <label style="font-size:0.8rem;display:block;margin-bottom:0.25rem">Giờ/tuần</label>
                      <input type="number" id="m-hours" min="1" value="2" style="width:100%;padding:0.5rem;border:1px solid var(--color-border);border-radius:6px" />
                    </div>
                    <div>
                      <label style="font-size:0.8rem;display:block;margin-bottom:0.25rem">Phí/giờ (VND)</label>
                      <input type="number" id="m-rate" min="0" value="0" placeholder="0 = volunteer" style="width:100%;padding:0.5rem;border:1px solid var(--color-border);border-radius:6px" />
                    </div>
                  </div>
                  <button type="submit" class="btn btn--primary">Đăng ký mentor</button>
                </form>
                <div id="m-msg" style="margin-top:1rem"></div>
              </div>
            </div>
          </main>
        </div>
      `;

      document.getElementById('logout-btn')?.addEventListener('click', (e) => {
        e.preventDefault();
        localStorage.removeItem('hmcv_token');
        window.location.href = '/login';
      });

      document.getElementById('mentor-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const domains = Array.from(document.querySelectorAll('input[name="domains"]:checked')).map((el: any) => el.value);
        const expertise = (document.getElementById('m-expertise') as HTMLInputElement).value.split(',').map((s: string) => s.trim()).filter(Boolean);
        try {
          await apiFetch('/projects/mentors', 'POST', {
            displayName: (document.getElementById('m-name') as HTMLInputElement).value,
            bio: (document.getElementById('m-bio') as HTMLTextAreaElement).value,
            bioEn: (document.getElementById('m-bio-en') as HTMLTextAreaElement).value,
            expertise,
            domains,
            yearsExperience: parseInt((document.getElementById('m-years') as HTMLInputElement).value),
            availabilityHoursPerWeek: parseInt((document.getElementById('m-hours') as HTMLInputElement).value),
            hourlyRateVnd: parseInt((document.getElementById('m-rate') as HTMLInputElement).value),
          });
          document.getElementById('m-msg')!.innerHTML = '<span style="color:var(--color-success)">✓ Đã đăng ký! Hồ sơ sẽ được xét duyệt trước khi hiển thị công khai.</span>';
          setTimeout(() => window.location.href = '/projects', 2000);
        } catch (err: any) {
          document.getElementById('m-msg')!.innerHTML = `<span style="color:#e53e3e">${err.message}</span>`;
        }
      });
    }

    init();
  </script>
</AppLayout>
