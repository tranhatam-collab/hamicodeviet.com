---
import AppLayout from '../layouts/AppLayout.astro';
---

<AppLayout title="Hoàn tiền — HaMi Code Việt">
  <div id="refunds-root">
    <div class="auth-container"><div class="auth-card"><h1 class="auth-title">Đang tải...</h1></div></div>
  </div>

  <script type="module">
    import { getCurrentUser, apiFetch } from '../lib/api';

    const root = document.getElementById('refunds-root')!;

    async function renderRefunds() {
      const user = await getCurrentUser();
      if (!user) { window.location.href = '/login'; return; }

      try {
        const data = await apiFetch('/refunds/me');
        renderList(data.refunds || []);
      } catch (err) {
        root.innerHTML = `<div class="dashboard"><div class="dashboard-main"><p>Không thể tải.</p></div></div>`;
      }
    }

    function renderList(refunds: any[]) {
      const cards = refunds.map(r => `
        <div class="card" style="padding:1.25rem">
          <div style="display:flex;justify-content:space-between;align-items:start">
            <div>
              <h3 style="font-size:1rem;margin:0 0 0.5rem">Refund #${r.id.substring(0,8)}</h3>
              <p style="font-size:0.85rem;color:var(--color-text-muted);margin:0">${r.reason || ''}</p>
              <p style="font-size:0.8rem;color:var(--color-text-muted);margin:0.25rem 0 0">Số tiền: $${(r.amount_cents/100).toFixed(2)}</p>
            </div>
            <span style="padding:0.3rem 0.75rem;border-radius:6px;font-size:0.75rem;font-weight:600;background:${r.status === 'approved' ? 'var(--color-success)' : r.status === 'pending' ? 'var(--color-creative-yellow)' : 'var(--color-border)'};color:${r.status === 'approved' ? 'white' : r.status === 'pending' ? '#102A43' : 'inherit'}">${r.status}</span>
          </div>
        </div>
      `).join('');

      root.innerHTML = `
        <div class="dashboard">
          <aside class="sidebar">
            <div class="sidebar-logo">HaMi <span class="code">&lt;CODE&gt;</span> Việt</div>
            <nav><ul class="sidebar-nav">
              <li><a href="/dashboard">📊 Dashboard</a></li>
              <li><a href="/courses">📚 Khóa học</a></li>
              <li><a href="/codelab">💻 CodeLab</a></li>
              <li><a href="/ai">🤖 AI Chat</a></li>
              <li><a href="/marketplace">🛒 Marketplace</a></li>
              <li><a href="/portfolio">🏆 Portfolio</a></li>
              <li><a href="/certificates">📜 Chứng chỉ</a></li>
              <li><a href="/refunds" class="active">💰 Hoàn tiền</a></li>
              <li><a href="/privacy">🔒 Quyền riêng tư</a></li>
              <li><a href="/settings">⚙️ Cài đặt</a></li>
              <li><a href="#" id="logout-btn">🚪 Đăng xuất</a></li>
            </ul></nav>
          </aside>
          <main class="dashboard-main">
            <div class="dashboard-header"><h1 class="dashboard-title">💰 Hoàn tiền</h1></div>
            <div class="dashboard-content">
              <div class="card" style="padding:1.5rem;margin-bottom:1.5rem">
                <h3 style="margin:0 0 1rem">Yêu cầu hoàn tiền</h3>
                <form id="refund-form" style="display:flex;flex-direction:column;gap:1rem">
                  <input type="text" id="r-payment-id" placeholder="Payment ID" required style="padding:0.5rem;border:1px solid var(--color-border);border-radius:6px" />
                  <textarea id="r-reason" rows="3" placeholder="Lý do hoàn tiền / Reason" required style="padding:0.5rem;border:1px solid var(--color-border);border-radius:6px"></textarea>
                  <button type="submit" class="btn btn--primary">Gửi yêu cầu / Submit</button>
                </form>
                <div id="r-status" style="margin-top:0.75rem"></div>
              </div>
              <h3 style="margin:0 0 1rem">Lịch sử hoàn tiền</h3>
              <div style="display:flex;flex-direction:column;gap:0.75rem">
                ${cards || '<p style="color:var(--color-text-muted)">Chưa có yêu cầu hoàn tiền.</p>'}
              </div>
            </div>
          </main>
        </div>
      `;

      document.getElementById('refund-form')?.addEventListener('submit', requestRefund);
      document.getElementById('logout-btn')?.addEventListener('click', (e) => {
        e.preventDefault();
        localStorage.removeItem('hmcv_token');
        window.location.href = '/login';
      });
    }

    async function requestRefund(e: Event) {
      e.preventDefault();
      const status = document.getElementById('r-status')!;
      try {
        await apiFetch('/refunds/request', 'POST', {
          paymentId: (document.getElementById('r-payment-id') as HTMLInputElement).value,
          reason: (document.getElementById('r-reason') as HTMLTextAreaElement).value,
        });
        status.innerHTML = '<span style="color:var(--color-success)">✓ Yêu cầu đã được gửi!</span>';
        setTimeout(() => location.reload(), 1500);
      } catch (err: any) {
        status.innerHTML = `<span style="color:#e53e3e">${err.message}</span>`;
      }
    }

    renderRefunds();
  </script>
</AppLayout>
