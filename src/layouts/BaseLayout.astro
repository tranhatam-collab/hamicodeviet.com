---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  lang?: 'vi' | 'en';
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'HaMi Code Việt — Học ngôn ngữ. Học lập trình. Làm ra sản phẩm thật.',
  lang = 'vi',
  ogImage = '/og-default.svg',
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);

// JSON-LD structured data
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'HaMi Code Việt',
  alternateName: 'HaMi Code Viet',
  url: 'https://hamicodeviet.com',
  logo: 'https://hamicodeviet.com/favicon.svg',
  description: 'Nền tảng giáo dục công nghệ song ngữ Việt-Anh dành cho người học 8-24 tuổi.',
  foundingDate: '2024',
  founder: { '@type': 'Person', name: 'Trần Đỗ Hà Mi' },
  address: { '@type': 'PostalAddress', addressCountry: 'VN' },
  sameAs: ['https://hamicodeviet.com'],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'HaMi Code Việt',
  url: 'https://hamicodeviet.com',
  inLanguage: ['vi', 'en'],
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://hamicodeviet.com/khoa-hoc?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
---

<!doctype html>
<html lang={lang} data-lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | HaMi Code Việt</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <!-- hreflang: bilingual signals for search engines -->
    {(() => {
      const viUrl = canonicalURL;
      const enUrl = new URL('/en' + Astro.url.pathname, Astro.site);
      return (
        <>
          <link rel="alternate" hreflang="vi" href={viUrl} />
          <link rel="alternate" hreflang="en" href={enUrl} />
          <link rel="alternate" hreflang="x-default" href={viUrl} />
        </>
      );
    })()}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | HaMi Code Việt`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={lang === 'vi' ? 'vi_VN' : 'en_US'} />
    <meta property="og:site_name" content="HaMi Code Việt" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | HaMi Code Việt`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.json" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- DNS prefetch for API -->
    <link rel="dns-prefetch" href="https://api.hamicodeviet.com" />
    <link rel="preconnect" href="https://api.hamicodeviet.com" />

    <!-- Theme color -->
    <meta name="theme-color" content="#102A43" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">
      <span data-vi>Bỏ qua đến nội dung chính</span>
      <span data-en>Skip to main content</span>
    </a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />

    <script>
      // Language toggle logic
      const LANG_KEY = 'hmcv-lang';
      const saved = localStorage.getItem(LANG_KEY) as 'vi' | 'en' | null;
      if (saved) {
        document.documentElement.setAttribute('data-lang', saved);
        document.documentElement.setAttribute('lang', saved);
      }

      function setLang(lang: string) {
        document.documentElement.setAttribute('data-lang', lang);
        document.documentElement.setAttribute('lang', lang);
        localStorage.setItem(LANG_KEY, lang);
        document.querySelectorAll('.lang-toggle button').forEach((btn) => {
          btn.classList.toggle('active', (btn as HTMLElement).dataset.lang === lang);
        });
      }

      document.querySelectorAll('.lang-toggle button').forEach((btn) => {
        const currentLang = document.documentElement.getAttribute('data-lang') ?? 'vi';
        btn.classList.toggle('active', (btn as HTMLElement).dataset.lang === currentLang);
        btn.addEventListener('click', () => {
          setLang((btn as HTMLElement).dataset.lang ?? 'vi');
        });
      });

      // Register service worker for PWA
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      }
    </script>
  </body>
</html>
