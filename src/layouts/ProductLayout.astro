---
import BaseLayout from '../layouts/BaseLayout.astro';

interface Props {
  title: string;
  ageGroup: string;
  ageColor: string;
  productType: string;
  description: string;
}

const { title, ageGroup, ageColor, productType, description } = Astro.props;
---

<BaseLayout title={`${title} — HaMi Code Việt`}>
  <main style="min-height:100vh">
    <div style="background:var(--color-navy);padding:1rem 1.5rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem">
      <div style="display:flex;align-items:center;gap:1rem">
        <a href="/san-pham" style="color:white;text-decoration:none;font-size:0.9rem">← Tất cả sản phẩm</a>
        <div style="background:{ageColor};color:white;padding:0.3rem 0.75rem;border-radius:6px;font-size:0.75rem;font-weight:700">{ageGroup} tuổi</div>
        <span style="color:rgba(255,255,255,0.6);font-size:0.75rem">{productType}</span>
      </div>
      <h1 style="color:white;font-size:1.2rem;margin:0;font-weight:700">{title}</h1>
    </div>
    <div style="padding:0.5rem 1.5rem;background:var(--color-bg-light);border-bottom:1px solid var(--color-border)">
      <p style="margin:0;font-size:0.85rem;color:var(--color-text-muted)">{description}</p>
    </div>
    <slot />
  </main>
</BaseLayout>
