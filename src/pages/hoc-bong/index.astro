---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Học bổng / Scholarship';
const description = 'Chương trình học bổng HaMi Code Việt — 100 suất Free Pass cho học sinh khó khăn. / HaMi Code Viet scholarship program — 100 Free Pass scholarships for underprivileged students.';
---

<BaseLayout title={title} description={description}>
  <section class="hero">
    <div class="container text-center">
      <p class="eyebrow" style="color: var(--color-creative-yellow);">
        <span data-vi>Cơ hội cho mọi người học</span>
        <span data-en>Opportunity for every learner</span>
      </p>
      <h1>
        <span data-vi>Học bổng HaMi Code Việt</span>
        <span data-en>HaMi Code Viet Scholarship</span>
      </h1>
      <p class="hero-subtitle">
        <span data-vi>100 suất Free Pass dành cho học sinh có hoàn cảnh khó khăn, giúp mọi trẻ em đều có cơ hội học công nghệ.</span>
        <span data-en>100 Free Pass scholarships for underprivileged students, giving every child a chance to learn technology.</span>
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="commitment-card">
        <h2 class="text-center mb-lg">
          <span data-vi>Cam kết của chúng tôi</span>
          <span data-en>Our commitment</span>
        </h2>
        <p class="text-center">
          <span data-vi>Chúng tôi cam kết trao 100 học bổng Free Pass trong năm đầu tiên, bao gồm truy cập đầy đủ bài học tự học, thử thách hàng tuần và hướng dẫn cơ bản từ cộng đồng.</span>
          <span data-en>We commit to awarding 100 Free Pass scholarships in the first year, including full access to self-paced lessons, weekly challenges, and basic community guidance.</span>
        </p>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <h2 class="text-center mb-xl">
        <span data-vi>Điều kiện đăng ký</span>
        <span data-en>Eligibility</span>
      </h2>
      <div class="grid grid--3">
        <div class="card requirement-card">
          <div class="req-icon">🎂</div>
          <h3>
            <span data-vi>Độ tuổi 8–17</span>
            <span data-en>Ages 8–17</span>
          </h3>
          <p>
            <span data-vi>Dành cho học sinh đang học tiểu học, THCS hoặc THPT.</span>
            <span data-en>For students in primary, middle, or high school.</span>
          </p>
        </div>
        <div class="card requirement-card">
          <div class="req-icon">🤝</div>
          <h3>
            <span data-vi>Hoàn cảnh khó khăn</span>
            <span data-en>Underprivileged background</span>
          </h3>
          <p>
            <span data-vi>Ưu tiên học sinh có hoàn cảnh kinh tế khó khăn, con em gia đình chính sách, vùng sâu vùng xa.</span>
            <span data-en>Priority for students from low-income families, policy beneficiary families, and remote areas.</span>
          </p>
        </div>
        <div class="card requirement-card">
          <div class="req-icon">📅</div>
          <h3>
            <span data-vi>Cam kết học 3 tháng</span>
            <span data-en>3-month learning commitment</span>
          </h3>
          <p>
            <span data-vi>Người nhận học bổng cam kết hoàn thành ít nhất 12 bài học trong 3 tháng.</span>
            <span data-en>Scholarship recipients commit to completing at least 12 lessons in 3 months.</span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="text-center mb-xl">
        <span data-vi>Cách đăng ký</span>
        <span data-en>How to apply</span>
      </h2>
      <div class="steps">
        <div class="step">
          <span class="step-number">1</span>
          <h3>
            <span data-vi>Điền đơn</span>
            <span data-en>Fill out the form</span>
          </h3>
          <p>
            <span data-vi>Cung cấp thông tin cá nhân, hoàn cảnh gia đình và lý do muốn học lập trình.</span>
            <span data-en>Provide personal information, family background, and reasons for wanting to learn coding.</span>
          </p>
        </div>
        <div class="step">
          <span class="step-number">2</span>
          <h3>
            <span data-vi>Xét duyệt</span>
            <span data-en>Review</span>
          </h3>
          <p>
            <span data-vi>Đội ngũ HaMi Code Việt xét duyệt hồ sơ dựa trên hoàn cảnh và cam kết học tập.</span>
            <span data-en>The HaMi Code Viet team reviews applications based on background and learning commitment.</span>
          </p>
        </div>
        <div class="step">
          <span class="step-number">3</span>
          <h3>
            <span data-vi>Nhận học bổng & bắt đầu học</span>
            <span data-en>Receive scholarship & start learning</span>
          </h3>
          <p>
            <span data-vi>Học sinh được cấp tài khoản Free Pass và lộ trình cá nhân hóa để bắt đầu.</span>
            <span data-en>Students receive a Free Pass account and a personalized track to begin.</span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container text-center">
      <p class="notice">
        <span data-vi>Chương trình học bổng đang được thiết kế — đăng ký để được thông báo sớm.</span>
        <span data-en>The scholarship program is being designed — register to be notified early.</span>
      </p>
      <a href="/lien-he" class="btn btn--accent btn--lg mt-lg">
        <span data-vi>Đăng ký nhận thông báo</span>
        <span data-en>Register for updates</span>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-subtitle { max-width: 720px; margin: 0 auto; }
  .commitment-card { max-width: 800px; margin: 0 auto; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-xl); padding: var(--space-2xl); }
  .commitment-card p { margin-bottom: 0; color: var(--color-text-muted); }
  .requirement-card { text-align: center; }
  .req-icon { font-size: 2.5rem; margin-bottom: var(--space-md); }
  .steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-lg); max-width: 960px; margin: 0 auto; }
  .step { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: var(--space-xl); position: relative; }
  .step-number { position: absolute; top: -20px; left: 50%; transform: translateX(-50%); width: 40px; height: 40px; border-radius: 50%; background: var(--color-tech-blue); color: white; display: grid; place-items: center; font-weight: 800; }
  .step h3 { margin-top: var(--space-md); margin-bottom: var(--space-sm); }
  .step p { margin-bottom: 0; color: var(--color-text-muted); font-size: 0.95rem; }
  .notice { max-width: 680px; margin: 0 auto; font-size: 1.1rem; color: rgba(247, 250, 252, 0.85); }
  @media (max-width: 768px) { .steps { grid-template-columns: 1fr; } }
</style>
