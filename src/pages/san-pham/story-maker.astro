---
import ProductLayout from '../../layouts/ProductLayout.astro';
---

<ProductLayout title="Story Maker" ageGroup="8-10" ageColor="#FFC857" productType="Video" description="Tạo truyện tương tác với nhân vật và bối cảnh"titleEn="Story Maker" productTypeEn="Video" descriptionEn="Create interactive stories with characters and settings">
  <div style="padding:1.5rem;max-width:900px;margin:0 auto">
    <div id="setup" style="background:white;border-radius:12px;padding:2rem;box-shadow:0 2px 8px rgba(0,0,0,0.1)">
      <h2 style="margin:0 0 1.5rem;font-size:1.3rem">📖 <span data-vi>Tạo câu chuyện của bạn</span><span data-en>Create your story</span></h2>
      <div style="display:grid;gap:1.5rem">
        <div>
          <label style="font-weight:700;display:block;margin-bottom:0.5rem"><span data-vi>Nhân vật</span><span data-en>Character</span></label>
          <div id="char-pick" style="display:flex;gap:0.75rem;flex-wrap:wrap"></div>
        </div>
        <div>
          <label style="font-weight:700;display:block;margin-bottom:0.5rem"><span data-vi>Bối cảnh</span><span data-en>Setting</span></label>
          <div id="setting-pick" style="display:flex;gap:0.75rem;flex-wrap:wrap"></div>
        </div>
        <div>
          <label style="font-weight:700;display:block;margin-bottom:0.5rem"><span data-vi>Tâm trạng</span><span data-en>Mood</span></label>
          <div id="mood-pick" style="display:flex;gap:0.75rem;flex-wrap:wrap"></div>
        </div>
        <button id="start-btn" style="padding:0.8rem 2rem;background:#FFC857;color:#102A43;border:none;border-radius:8px;font-size:1rem;font-weight:700;cursor:pointer"><span data-vi>Bắt đầu</span><span data-en>Start</span> →</button>
      </div>
    </div>
    <div id="story" style="display:none;background:white;border-radius:12px;padding:2rem;box-shadow:0 2px 8px rgba(0,0,0,0.1);min-height:400px"></div>
  </div>

  <script type="module">
    const lang = document.documentElement.dataset.lang || 'vi';
    const t = (vi: string, en: string) => lang === 'vi' ? vi : en;
    const characters = [
      { id: 'hero', icon: '🦸', nameVi: 'Anh hùng', nameEn: 'Hero' },
      { id: 'animal', icon: '🐱', nameVi: 'Động vật', nameEn: 'Animal' },
      { id: 'robot', icon: '🤖', nameVi: 'Robot', nameEn: 'Robot' },
      { id: 'wizard', icon: '🧙', nameVi: 'Phù thủy', nameEn: 'Wizard' },
      { id: 'astronaut', icon: '👨‍🚀', nameVi: 'Phi hành gia', nameEn: 'Astronaut' },
      { id: 'princess', icon: '👸', nameVi: 'Công chúa', nameEn: 'Princess' },
    ];
    const settings = [
      { id: 'forest', icon: '🌲', nameVi: 'Khu rừng', nameEn: 'Forest' },
      { id: 'space', icon: '🚀', nameVi: 'Vũ trụ', nameEn: 'Space' },
      { id: 'castle', icon: '🏰', nameVi: 'Lâu đài', nameEn: 'Castle' },
      { id: 'ocean', icon: '🌊', nameVi: 'Đại dương', nameEn: 'Ocean' },
      { id: 'city', icon: '🏙️', nameVi: 'Thành phố', nameEn: 'City' },
      { id: 'jungle', icon: '🌴', nameVi: 'Rừng rậm', nameEn: 'Jungle' },
    ];
    const moods = [
      { id: 'happy', icon: '😊', nameVi: 'Vui vẻ', nameEn: 'Happy' },
      { id: 'scary', icon: '😱', nameVi: 'Hồi hộp', nameEn: 'Scary' },
      { id: 'funny', icon: '😂', nameVi: 'Hài hước', nameEn: 'Funny' },
      { id: 'mysterious', icon: '🔍', nameVi: 'Bí ẩn', nameEn: 'Mysterious' },
    ];

    let selected = { char: null, setting: null, mood: null };

    function renderPicks(containerId, items, key) {
      const c = document.getElementById(containerId)!;
      c.innerHTML = items.map(i => `
        <button data-id="${i.id}" style="display:flex;flex-direction:column;align-items:center;gap:0.25rem;padding:0.75rem 1rem;border:2px solid #ddd;border-radius:10px;background:white;cursor:pointer;font-size:0.8rem;min-width:80px">
          <span style="font-size:1.8rem">${i.icon}</span>
          <span>${t(i.nameVi, i.nameEn)}</span>
        </button>
      `).join('');
      c.querySelectorAll('button').forEach(btn => {
        btn.addEventListener('click', () => {
          c.querySelectorAll('button').forEach(b => b.style.borderColor = '#ddd');
          (btn as HTMLElement).style.borderColor = '#FFC857';
          selected[key] = (btn as HTMLElement).dataset.id;
        });
      });
    }

    renderPicks('char-pick', characters, 'char');
    renderPicks('setting-pick', settings, 'setting');
    renderPicks('mood-pick', moods, 'mood');

    document.getElementById('start-btn')!.addEventListener('click', () => {
      if (!selected.char || !selected.setting || !selected.mood) {
        alert(t('Vui lòng chọn tất cả!', 'Please pick all three!'));
        return;
      }
      startStory();
    });

    const stories: Record<string, any> = {
      intro: {
        text: (s: any) => {
          const char = characters.find(c => c.id === s.char)!;
          const setting = settings.find(c => c.id === s.setting)!;
          const mood = moods.find(c => c.id === s.mood)!;
          return t(
            `Một ngày ${mood.id === 'happy' ? 'đẹp trời' : mood.id === 'scary' ? 'tăm tối' : mood.id === 'funny' ? 'vui nhộn' : 'bí ẩn'}, ${char.icon} ${char.nameVi} bước vào ${setting.icon} ${setting.nameVi}. ${mood.id === 'mysterious' ? 'Có gì đó không ổn...' : 'Một cuộc phiêu lưu bắt đầu!'}`,
            `One ${mood.id === 'happy' ? 'beautiful' : mood.id === 'scary' ? 'dark' : mood.id === 'funny' ? 'funny' : 'mysterious'} day, ${char.icon} ${char.nameEn} steps into ${setting.icon} ${setting.nameEn}. ${mood.id === 'mysterious' ? 'Something is not right...' : 'An adventure begins!'}`
          );
        },
        choices: [
          { textVi: '🔍 Khám phá xung quanh', textEn: '🔍 Explore', next: 'explore' },
          { textVi: '🗣️ Gặp ai đó', textEn: '🗣️ Meet someone', next: 'meet' },
          { textVi: '🏃 Chạy nhanh', textEn: '🏃 Run fast', next: 'run' },
        ],
      },
      explore: {
        text: () => t(`Bạn tìm thấy một vật thể kỳ lạ phát sáng. Nó trông như một chiếc chìa khóa cổ!`, `You find a strange glowing object. It looks like an ancient key!`),
        choices: [
          { textVi: '🔑 Nhặt lên', textEn: '🔑 Pick it up', next: 'key' },
          { textVi: '🚪 Tìm cửa', textEn: '🚪 Find a door', next: 'door' },
          { textVi: '🔙 Quay lại', textEn: '🔙 Go back', next: 'intro' },
        ],
      },
      meet: {
        text: () => t(`Bạn gặp một nhân vật bí ẩn. "Ta đã chờ ngươi lâu rồi," họ nói.`, `You meet a mysterious figure. "I have been waiting for you," they say.`),
        choices: [
          { textVi: '❓ Hỏi họ là ai', textEn: '❓ Ask who they are', next: 'reveal' },
          { textVi: '🎁 Nhận quà', textEn: '🎁 Accept gift', next: 'gift' },
          { textVi: '🏃 Bỏ chạy', textEn: '🏃 Run away', next: 'run' },
        ],
      },
      run: {
        text: () => t(`Bạn chạy nhanh nhất có thể! Nhưng rồi bạn thấy một lối đi hẹp dẫn đến nơi an toàn.`, `You run as fast as you can! But then you see a narrow passage leading to safety.`),
        choices: [
          { textVi: '🚪 Vào lối đi', textEn: '🚪 Enter passage', next: 'safe' },
          { textVi: '🔍 Dừng lại xem', textEn: '🔍 Stop and look', next: 'explore' },
        ],
      },
      key: {
        text: () => t(`Chiếc chìa khóa phát sáng trong tay bạn. Phía trước có một cánh cửa cổ. Chìa khóa vừa khít!`, `The key glows in your hand. Ahead is an ancient door. The key fits perfectly!`),
        choices: [
          { textVi: '🚪 Mở cửa', textEn: '🚪 Open door', next: 'treasure' },
          { textVi: '🔙 Quay lại', textEn: '🔙 Go back', next: 'explore' },
        ],
      },
      door: {
        text: () => t(`Bạn tìm thấy một cánh cửa lớn bị khóa. Có vẻ cần một chiếc chìa khóa...`, `You find a large locked door. It seems to need a key...`),
        choices: [
          { textVi: '🔍 Tìm chìa khóa', textEn: '🔍 Search for key', next: 'explore' },
          { textVi: '💪 Cố gắng phá', textEn: '💪 Try to break', next: 'break' },
        ],
      },
      reveal: {
        text: () => t(`"Ta là người bảo vệ nơi này," họ nói. "Ngươi đã được chọn để hoàn thành nhiệm vụ."`, `"I am the guardian of this place," they say. "You have been chosen to complete a quest."`),
        choices: [
          { textVi: '✅ Nhận nhiệm vụ', textEn: '✅ Accept quest', next: 'quest' },
          { textVi: '❌ Từ chối', textEn: '❌ Refuse', next: 'refuse' },
        ],
      },
      gift: {
        text: () => t(`Họ đưa cho bạn một viên pha lê phát sáng. "Sẽ có lúc cần đến," họ nói rồi biến mất.`, `They hand you a glowing crystal. "You will need it," they say and vanish.`),
        choices: [
          { textVi: '🔮 Tiếp tục phiêu lưu', textEn: '🔮 Continue adventure', next: 'explore' },
          { textVi: '🏁 Kết thúc', textEn: '🏁 End story', next: 'end' },
        ],
      },
      safe: {
        text: () => t(`Bạn đến nơi an toàn. Nhưng phiêu lưu vẫn chưa kết thúc...`, `You reach safety. But the adventure is not over yet...`),
        choices: [
          { textVi: '🔍 Tiếp tục khám phá', textEn: '🔍 Continue exploring', next: 'explore' },
          { textVi: '🏁 Kết thúc', textEn: '🏁 End story', next: 'end' },
        ],
      },
      treasure: {
        text: () => t(`Cánh cửa mở ra! Bên trong là một kho báu sáng chói. Bạn đã tìm thấy kho báu! 🎉`, `The door opens! Inside is a shining treasure. You found the treasure! 🎉`),
        choices: [{ textVi: '🏁 Kết thúc', textEn: '🏁 End story', next: 'end' }],
      },
      break: {
        text: () => t(`Cánh cửa quá mạnh. Bạn cần tìm cách khác.`, `The door is too strong. You need to find another way.`),
        choices: [{ textVi: '🔍 Tìm chìa khóa', textEn: '🔍 Search for key', next: 'explore' }],
      },
      quest: {
        text: () => t(`"Hãy tìm kho báu bị giấu trong nơi này," họ nói. "Nhưng cẩn thận với cạm bẫy!"`, `"Find the treasure hidden in this place," they say. "But beware of traps!"`),
        choices: [
          { textVi: '🔍 Bắt đầu tìm kiếm', textEn: '🔍 Start searching', next: 'explore' },
          { textVi: '❓ Hỏi thêm', textEn: '❓ Ask more', next: 'reveal' },
        ],
      },
      refuse: {
        text: () => t(`"Rất tiếc," họ nói. "Cơ hội không đến lần thứ hai." Họ biến mất.`, `"I'm sorry," they say. "Opportunities don't come twice." They vanish.`),
        choices: [{ textVi: '🏁 Kết thúc', textEn: '🏁 End story', next: 'end' }],
      },
      end: {
        text: () => t(`Câu chuyện kết thúc. Cảm ơn bạn đã chơi! 🌟`, `The story ends. Thanks for playing! 🌟`),
        choices: [{ textVi: '🔄 Chơi lại', textEn: '🔄 Play again', next: 'restart' }],
      },
    };

    let history: string[] = [];

    function startStory() {
      document.getElementById('setup')!.style.display = 'none';
      document.getElementById('story')!.style.display = 'block';
      history = [];
      renderNode('intro');
    }

    function renderNode(nodeId: string) {
      if (nodeId === 'restart') { location.reload(); return; }
      history.push(nodeId);
      const node = stories[nodeId];
      if (!node) return;
      const text = typeof node.text === 'function' ? node.text(selected) : node.text;
      const story = document.getElementById('story')!;
      story.innerHTML = `
        <div style="font-size:1.1rem;line-height:1.8;margin-bottom:1.5rem;min-height:100px" id="story-text"></div>
        <div id="choices" style="display:flex;flex-direction:column;gap:0.75rem"></div>
        <div style="margin-top:1.5rem;display:flex;gap:0.5rem">
          <button id="export-btn" style="padding:0.5rem 1rem;background:#20A779;color:white;border:none;border-radius:6px;cursor:pointer">📥 ${t('Xuất truyện', 'Export')}</button>
          <button id="restart-btn" style="padding:0.5rem 1rem;background:#ddd;border:none;border-radius:6px;cursor:pointer">🔄 ${t('Chơi lại', 'Play again')}</button>
        </div>
      `;
      // Animated text reveal
      const textEl = document.getElementById('story-text')!;
      let i = 0;
      const interval = setInterval(() => {
        if (i >= text.length) { clearInterval(interval); return; }
        textEl.textContent += text[i];
        i++;
      }, 30);
      // Render choices after text
      setTimeout(() => {
        const choicesEl = document.getElementById('choices')!;
        choicesEl.innerHTML = node.choices.map((c: any, idx: number) => `
          <button data-next="${c.next}" style="padding:0.75rem 1.5rem;background:#FFC857;color:#102A43;border:none;border-radius:8px;cursor:pointer;font-weight:600;text-align:left;font-size:0.95rem">${t(c.textVi, c.textEn)}</button>
        `).join('');
        choicesEl.querySelectorAll('button').forEach(btn => {
          btn.addEventListener('click', () => renderNode((btn as HTMLElement).dataset.next!));
        });
      }, text.length * 30 + 200);

      document.getElementById('export-btn')!.addEventListener('click', exportStory);
      document.getElementById('restart-btn')!.addEventListener('click', () => location.reload());
    }

    function exportStory() {
      const html = `<!DOCTYPE html><html><head><meta charset="UTF-8"><title>My Story</title><style>body{font-family:Georgia,serif;max-width:600px;margin:2rem auto;padding:1rem;line-height:1.8}h1{color:#FFC857}</style></head><body><h1>📖 ${t('Câu chuyện của tôi', 'My Story')}</h1><p>${t('Nhân vật', 'Character')}: ${t(characters.find(c=>c.id===selected.char)?.nameVi || '', characters.find(c=>c.id===selected.char)?.nameEn || '')}</p><p>${t('Bối cảnh', 'Setting')}: ${t(settings.find(s=>s.id===selected.setting)?.nameVi || '', settings.find(s=>s.id===selected.setting)?.nameEn || '')}</p><p>${t('Tâm trạng', 'Mood')}: ${t(moods.find(m=>m.id===selected.mood)?.nameVi || '', moods.find(m=>m.id===selected.mood)?.nameEn || '')}</p><hr><p>${t('Đường đi', 'Path')}: ${history.join(' → ')}</p></body></html>`;
      const blob = new Blob([html], { type: 'text/html' });
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = 'my-story.html';
      a.click();
    }
  </script>
</ProductLayout>
