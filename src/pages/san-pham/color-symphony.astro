---
import ProductLayout from '../../layouts/ProductLayout.astro';
---

<ProductLayout title="Color Symphony" ageGroup="8-10" ageColor="#FFC857" productType="Âm thanh + Hình ảnh" description="Vẽ tranh bằng âm thanh — nghệ thuật âm hình"titleEn="Color Symphony" productTypeEn="Audio + Image" descriptionEn="Paint with sound — audio-visual art">
  <div style="padding:1.5rem;max-width:900px;margin:0 auto">
    <div style="background:white;border-radius:12px;padding:1.5rem;box-shadow:0 2px 8px rgba(0,0,0,0.1)">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;flex-wrap:wrap;gap:0.5rem">
        <div style="display:flex;gap:0.5rem;flex-wrap:wrap">
          <button id="play-btn" style="padding:0.5rem 1rem;background:#FFC857;color:#102A43;border:none;border-radius:6px;cursor:pointer;font-weight:600">🎨 <span data-vi>Vẽ + Âm thanh</span><span data-en>Draw + Sound</span></button>
          <button id="clear-btn" style="padding:0.5rem 1rem;background:#ddd;border:none;border-radius:6px;cursor:pointer">🗑️ <span data-vi>Xóa</span><span data-en>Clear</span></button>
          <button id="save-btn" style="padding:0.5rem 1rem;background:#20A779;color:white;border:none;border-radius:6px;cursor:pointer">📥 <span data-vi>Tải PNG</span><span data-en>Save PNG</span></button>
        </div>
        <div style="display:flex;align-items:center;gap:0.5rem">
          <label style="font-size:0.85rem">🎵 <span data-vi>Âm:</span><span data-en>Wave:</span></label>
          <select id="wave-type" style="padding:0.3rem;border-radius:4px;border:1px solid #ddd">
            <option value="sine"><span data-vi>Sine (êm)</span><span data-en>Sine (smooth)</span></option>
            <option value="triangle">Triangle</option>
            <option value="square">Square</option>
            <option value="sawtooth">Sawtooth</option>
          </select>
        </div>
      </div>
      <canvas id="canvas" width="800" height="500" style="width:100%;border-radius:8px;background:#081826;cursor:crosshair;display:block"></canvas>
      <p style="text-align:center;color:#666;margin-top:0.5rem;font-size:0.85rem"><span data-vi>Vẽ trên canvas — mỗi vị trí tạo ra một nốt nhạc!</span><span data-en>Draw on canvas — each position makes a note!</span></p>
    </div>
  </div>

  <script type="module">
    const canvas = document.getElementById('canvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    let audioCtx: AudioContext | null = null;
    let isDrawing = false;
    let waveType = 'sine';

    function getAudio() {
      if (!audioCtx) audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
      return audioCtx;
    }

    function playNote(x: number, y: number) {
      const ac = getAudio();
      const osc = ac.createOscillator();
      const gain = ac.createGain();
      // Map x position to frequency (200-800 Hz)
      const freq = 200 + (x / canvas.width) * 600;
      // Map y position to volume
      const vol = 0.1 + (1 - y / canvas.height) * 0.2;
      osc.type = waveType as OscillatorType;
      osc.frequency.value = freq;
      gain.gain.setValueAtTime(vol, ac.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.001, ac.currentTime + 0.3);
      osc.connect(gain);
      gain.connect(ac.destination);
      osc.start();
      osc.stop(ac.currentTime + 0.3);
    }

    function freqToColor(x: number) {
      const hue = (x / canvas.width) * 360;
      return `hsl(${hue}, 80%, 60%)`;
    }

    function getPos(e: MouseEvent | TouchEvent) {
      const rect = canvas.getBoundingClientRect();
      const scaleX = canvas.width / rect.width;
      const scaleY = canvas.height / rect.height;
      if (e instanceof MouseEvent) {
        return { x: (e.clientX - rect.left) * scaleX, y: (e.clientY - rect.top) * scaleY };
      }
      const t = e.touches[0];
      return { x: (t.clientX - rect.left) * scaleX, y: (t.clientY - rect.top) * scaleY };
    }

    function startDraw(e: MouseEvent | TouchEvent) {
      e.preventDefault();
      isDrawing = true;
      const { x, y } = getPos(e);
      ctx.beginPath();
      ctx.moveTo(x, y);
      ctx.lineWidth = 8;
      ctx.lineCap = 'round';
      ctx.strokeStyle = freqToColor(x);
      ctx.shadowBlur = 15;
      ctx.shadowColor = freqToColor(x);
      playNote(x, y);
    }

    function draw(e: MouseEvent | TouchEvent) {
      if (!isDrawing) return;
      e.preventDefault();
      const { x, y } = getPos(e);
      ctx.strokeStyle = freqToColor(x);
      ctx.shadowColor = freqToColor(x);
      ctx.lineTo(x, y);
      ctx.stroke();
      // Play note every ~80px movement
      if (Math.random() > 0.7) playNote(x, y);
    }

    function stopDraw() { isDrawing = false; }

    canvas.addEventListener('mousedown', startDraw);
    canvas.addEventListener('mousemove', draw);
    canvas.addEventListener('mouseup', stopDraw);
    canvas.addEventListener('mouseleave', stopDraw);
    canvas.addEventListener('touchstart', startDraw);
    canvas.addEventListener('touchmove', draw);
    canvas.addEventListener('touchend', stopDraw);

    document.getElementById('clear-btn')!.addEventListener('click', () => {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.fillStyle = '#081826';
      ctx.fillRect(0, 0, canvas.width, canvas.height);
    });

    document.getElementById('save-btn')!.addEventListener('click', () => {
      const a = document.createElement('a');
      a.href = canvas.toDataURL('image/png');
      a.download = 'color-symphony.png';
      a.click();
    });

    document.getElementById('wave-type')!.addEventListener('change', (e) => {
      waveType = (e.target as HTMLSelectElement).value;
    });

    // Initialize canvas background
    ctx.fillStyle = '#081826';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
  </script>
</ProductLayout>
