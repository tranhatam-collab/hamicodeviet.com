---
import ProductLayout from '../../layouts/ProductLayout.astro';
---

<ProductLayout title="Chatbot Builder" ageGroup="14-17" ageColor="#20A779" productType="Demo" description="Tạo chatbot theo quy tắc, nhúng vào web"titleEn="Chatbot Builder" productTypeEn="Demo" descriptionEn="Create rule-based chatbots, embed in web">
  <div style="padding:1.5rem;max-width:1000px;margin:0 auto">
    <div style="display:grid;grid-template-columns:1fr 350px;gap:1.5rem">
      <div style="background:white;border-radius:12px;padding:1.5rem;box-shadow:0 2px 8px rgba(0,0,0,0.1)">
        <h2 style="margin:0 0 1rem;font-size:1.1rem">🤖 Rule Editor</h2>
        <div style="margin-bottom:1rem">
          <label style="font-weight:600;font-size:0.85rem;display:block;margin-bottom:0.25rem">Welcome message</label>
          <input type="text" id="welcome" style="width:100%;padding:0.5rem;border:1px solid #ddd;border-radius:6px" />
        </div>
        <div id="rules-list" style="display:flex;flex-direction:column;gap:0.75rem;margin-bottom:1rem"></div>
        <button id="add-rule-btn" style="padding:0.5rem 1rem;background:#20A779;color:white;border:none;border-radius:6px;cursor:pointer">+ <span data-vi>Thêm quy tắc</span><span data-en>Add rule</span></button>
        <div style="margin-top:1.5rem;display:flex;gap:0.5rem">
          <button id="export-json-btn" style="padding:0.5rem 1rem;background:#6C5CE7;color:white;border:none;border-radius:6px;cursor:pointer">📥 Export JSON</button>
          <button id="export-embed-btn" style="padding:0.5rem 1rem;background:#00A8CC;color:white;border:none;border-radius:6px;cursor:pointer">📋 Embed code</button>
        </div>
      </div>
      <div style="background:white;border-radius:12px;padding:0;box-shadow:0 2px 8px rgba(0,0,0,0.1);display:flex;flex-direction:column;height:500px">
        <div style="background:#20A779;color:white;padding:0.75rem 1rem;font-weight:600;border-radius:12px 12px 0 0">💬 Test Chat</div>
        <div id="chat-messages" style="flex:1;overflow-y:auto;padding:1rem;display:flex;flex-direction:column;gap:0.5rem"></div>
        <div style="display:flex;gap:0.5rem;padding:0.75rem;border-top:1px solid #eee">
          <input type="text" id="chat-input" style="flex:1;padding:0.5rem;border:1px solid #ddd;border-radius:6px" />
          <button id="chat-send" style="padding:0.5rem 1rem;background:#20A779;color:white;border:none;border-radius:6px;cursor:pointer"><span data-vi>Gửi</span><span data-en>Send</span></button>
        </div>
      </div>
    </div>
  </div>

  <script type="module">
    const lang = document.documentElement.dataset.lang || 'vi';
    const t = (vi: string, en: string) => lang === 'vi' ? vi : en;

    interface Rule { id: number; keywords: string; response: string; }
    let rules: Rule[] = [
      { id: 1, keywords: 'hello, hi, chào', response: t('Xin chào! Rất vui được gặp bạn 😊', 'Hello! Nice to meet you 😊') },
      { id: 2, keywords: 'bye, tạm biệt', response: t('Tạm biệt! Hẹn gặp lại 👋', 'Goodbye! See you again 👋') },
    ];

    (document.getElementById('welcome') as HTMLInputElement).value = t('Xin chào! Tôi có thể giúp gì cho bạn?', 'Hello! How can I help you?');
    (document.getElementById('chat-input') as HTMLInputElement).placeholder = t('Nhập tin nhắn...', 'Type a message...');

    function renderRules() {
      const list = document.getElementById('rules-list')!;
      list.innerHTML = rules.map(r => `
        <div data-id="${r.id}" style="display:flex;gap:0.5rem;align-items:center;padding:0.75rem;background:#f9f9f9;border-radius:8px">
          <div style="flex:1;display:grid;grid-template-columns:1fr 1fr;gap:0.5rem">
            <input type="text" class="rule-kw" value="${r.keywords}" placeholder="${t('Keywords (cách nhau bởi dấu phẩy)', 'Keywords (comma separated)')}" style="padding:0.4rem;border:1px solid #ddd;border-radius:4px;font-size:0.85rem" />
            <input type="text" class="rule-rs" value="${r.response}" placeholder="Response" style="padding:0.4rem;border:1px solid #ddd;border-radius:4px;font-size:0.85rem" />
          </div>
          <button class="rule-del" style="padding:0.3rem 0.6rem;background:#e53e3e;color:white;border:none;border-radius:4px;cursor:pointer">✕</button>
        </div>
      `).join('');
      list.querySelectorAll('[data-id]').forEach(el => {
        const id = parseInt((el as HTMLElement).dataset.id!);
        (el.querySelector('.rule-kw') as HTMLInputElement).addEventListener('input', (e) => { const r = rules.find(x=>x.id===id); if(r) r.keywords = (e.target as HTMLInputElement).value; });
        (el.querySelector('.rule-rs') as HTMLInputElement).addEventListener('input', (e) => { const r = rules.find(x=>x.id===id); if(r) r.response = (e.target as HTMLInputElement).value; });
        el.querySelector('.rule-del')!.addEventListener('click', () => { rules = rules.filter(x=>x.id!==id); renderRules(); });
      });
    }

    function getBotResponse(msg: string): string {
      const lower = msg.toLowerCase();
      for (const r of rules) {
        const kws = r.keywords.toLowerCase().split(',').map(k=>k.trim());
        if (kws.some(k => lower.includes(k))) return r.response;
      }
      return t('Xin lỗi, tôi không hiểu. Thử hỏi khác nhé!', 'Sorry, I don\'t understand that. Try asking something else!');
    }

    function addMessage(text: string, isBot: boolean) {
      const msgs = document.getElementById('chat-messages')!;
      const div = document.createElement('div');
      div.style.cssText = `max-width:80%;padding:0.6rem 0.8rem;border-radius:8px;font-size:0.85rem;${isBot?'background:#20A77920;color:#102A43;align-self:flex-start':'background:#00A8CC;color:white;align-self:flex-end'}`;
      div.textContent = text;
      msgs.appendChild(div);
      msgs.scrollTop = msgs.scrollHeight;
    }

    function sendMessage() {
      const input = document.getElementById('chat-input') as HTMLInputElement;
      const msg = input.value.trim();
      if (!msg) return;
      addMessage(msg, false);
      input.value = '';
      setTimeout(() => addMessage(getBotResponse(msg), true), 500);
    }

    document.getElementById('add-rule-btn')!.addEventListener('click', () => { rules.push({ id: Date.now(), keywords: '', response: '' }); renderRules(); });
    document.getElementById('chat-send')!.addEventListener('click', sendMessage);
    document.getElementById('chat-input')!.addEventListener('keydown', (e) => { if (e.key === 'Enter') sendMessage(); });
    document.getElementById('export-json-btn')!.addEventListener('click', () => {
      const data = { welcome: (document.getElementById('welcome') as HTMLInputElement).value, rules };
      const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
      const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'chatbot.json'; a.click();
    });
    document.getElementById('export-embed-btn')!.addEventListener('click', () => {
      const data = { welcome: (document.getElementById('welcome') as HTMLInputElement).value, rules };
      const embed = `<script src="https://hamicodeviet.com/chatbot.js" data-config='${JSON.stringify(data)}'><\/script>`;
      navigator.clipboard.writeText(embed).then(() => alert(t('Embed code đã copy!', 'Embed code copied!')));
    });

    renderRules();
    addMessage((document.getElementById('welcome') as HTMLInputElement).value, true);
  </script>
</ProductLayout>
