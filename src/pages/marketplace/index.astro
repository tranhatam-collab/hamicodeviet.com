---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="HaMi Market — Chợ sản phẩm số"
  description="Marketplace cho sản phẩm số của người học HaMi Code Việt — đang xây dựng."
>

<section style="background:linear-gradient(135deg,#081826 0%,#102A43 100%);color:#F7FAFC;padding:5rem 0" aria-labelledby="market-hero">
  <div class="container text-center">
    <p class="eyebrow" style="color:#20A779">HaMi Market</p>
    <h1 id="market-hero" style="color:#F7FAFC">
      <span data-vi>Chợ sản phẩm số</span>
      <span data-en>Digital marketplace</span>
    </h1>
    <p style="color:rgba(247,250,252,0.8);font-size:1.1rem;max-width:580px;margin:1rem auto 2rem">
      <span data-vi>Nơi người học bán sản phẩm số họ tự tạo: template, game, mã nguồn, asset, AI workflow và nhiều hơn nữa.</span>
      <span data-en>Where learners sell digital products they build: templates, games, source code, assets, AI workflows, and more.</span>
    </p>
    <div style="display:inline-flex;align-items:center;gap:0.75rem;background:rgba(255,200,87,0.12);border:1px solid rgba(255,200,87,0.3);border-radius:9999px;padding:0.5rem 1.5rem">
      <span style="color:#FFC857;font-weight:700">
        <span data-vi>🚧 Đang xây dựng — Ra mắt Q4 2026</span>
        <span data-en>🚧 Under construction — Launching Q4 2026</span>
      </span>
    </div>
  </div>
</section>

<section class="section" aria-labelledby="market-products">
  <div class="container">
    <h2 id="market-products" class="text-center">
      <span data-vi>Loại sản phẩm được bán</span>
      <span data-en>Types of products for sale</span>
    </h2>
    <div class="grid grid--4" style="margin-top:2rem">
      {['Template', 'Mã nguồn / Source code', 'Game', 'Asset & hình ảnh / Images', 'Animation', 'Worksheet', 'Plugin', 'AI workflow', 'SaaS nhỏ / Mini SaaS', 'Bài giảng / Lesson set', 'Công cụ giáo dục / Education tool', 'Dashboard'].map(t => (
        <div class="card" style="text-align:center;padding:1.25rem">
          <span style="font-size:0.9rem;font-weight:600">{t}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="section section--alt" aria-labelledby="market-requirements">
  <div class="container">
    <div style="max-width:700px;margin:0 auto">
      <h2 id="market-requirements" class="text-center">
        <span data-vi>Điều kiện để đăng sản phẩm</span>
        <span data-en>Requirements to list a product</span>
      </h2>
      <div style="margin-top:2rem;display:flex;flex-direction:column;gap:1rem">
        {[
          { vi: 'Xác minh danh tính người bán', en: 'Seller identity verified' },
          { vi: 'Chứng minh quyền sở hữu nội dung', en: 'Content ownership proven' },
          { vi: 'Khai báo thành phần do AI tạo ra', en: 'AI-generated content disclosed' },
          { vi: 'Quét mã độc và test vượt qua', en: 'Malware scan and tests passed' },
          { vi: 'Giấy phép sử dụng rõ ràng', en: 'Clear usage license' },
          { vi: 'Hướng dẫn sử dụng đầy đủ', en: 'Complete usage instructions' },
        ].map((r, i) => (
          <div style="display:flex;align-items:center;gap:1rem;padding:1rem 1.25rem;background:var(--color-surface);border-radius:10px;border:1px solid var(--color-border)">
            <span style="width:28px;height:28px;border-radius:50%;background:var(--color-tech-blue);color:white;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.85rem;flex-shrink:0">{i+1}</span>
            <span>
              <span data-vi>{r.vi}</span>
              <span data-en>{r.en}</span>
            </span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<section class="section" aria-labelledby="market-under18">
  <div class="container" style="max-width:700px;margin:0 auto">
    <h2 id="market-under18">
      <span data-vi>⚠️ Quy định với người dưới 18 tuổi</span>
      <span data-en>⚠️ Rules for under-18 sellers</span>
    </h2>
    <p>
      <span data-vi>Toàn bộ giao dịch, hợp đồng, quyền nhận tiền và xử lý tranh chấp của người dưới 18 tuổi phải thông qua tài khoản phụ huynh hoặc người đại diện hợp pháp.</span>
      <span data-en>All transactions, contracts, payment rights, and dispute resolution for under-18 users must go through a parent or legal guardian account.</span>
    </p>
  </div>
</section>

<section class="section section--dark" aria-labelledby="market-notify">
  <div class="container text-center">
    <h2 id="market-notify" style="color:#F7FAFC">
      <span data-vi>Đăng ký để được thông báo khi Marketplace mở</span>
      <span data-en>Register to be notified when Marketplace opens</span>
    </h2>
    <p style="color:rgba(247,250,252,0.75);margin:1rem 0 2rem">
      <span data-vi>Liên hệ với chúng tôi để đăng ký danh sách chờ.</span>
      <span data-en>Contact us to join the waitlist.</span>
    </p>
    <a href="/lien-he" class="btn btn--accent btn--lg">
      <span data-vi>Đăng ký danh sách chờ →</span>
      <span data-en>Join waitlist →</span>
    </a>
  </div>
</section>

</BaseLayout>
